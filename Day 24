Q4.Binary Tree Postorder Traversal (Leetcode - 145)

class Solution {
public:
    
    void postorder(TreeNode* root,vector<int> &vt){
        if(!root) return;

        postorder(root->left,vt);
        postorder(root->right,vt);
        vt.push_back(root->val);
    }

    vector<int> postorderTraversal(TreeNode* root) {
        vector<int> ans;

        postorder(root,ans);
        return ans;

    }
};
